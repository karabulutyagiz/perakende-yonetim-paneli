# App
APP_NAME=Gokce Toptan
APP_ENV=development
APP_DEBUG=true
APP_TIMEZONE=Europe/Istanbul

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Database
DATABASE_URL=postgresql+asyncpg://gokce:gokce@localhost:5432/gokce_toptan
DATABASE_SYNC_URL=postgresql+psycopg2://gokce:gokce@localhost:5432/gokce_toptan

# JWT (production'da Secrets Manager'dan gelecek)
JWT_SECRET=change-me-in-production-please-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_MINUTES=30
JWT_REFRESH_TOKEN_DAYS=14

# Argon2
ARGON2_TIME_COST=3
ARGON2_MEMORY_COST=65536
ARGON2_PARALLELISM=4

# AWS / S3
AWS_REGION=eu-central-1
S3_BUCKET=gokce-toptan-products
S3_PRESIGN_EXPIRES=600
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Rate limiting
RATE_LIMIT_LOGIN=5/minute
