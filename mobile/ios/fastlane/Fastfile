default_platform(:ios)

# App Store Connect API key — .p8 dosyası repoya GIRMEZ, standart konumda tutulur.
APP_IDENTIFIER = "com.parasende.app"
TEAM_ID = "5C2NRK938T"
API_KEY_ID = ENV["ASC_KEY_ID"] || "K3YS3S4G5T"
API_ISSUER_ID = ENV["ASC_ISSUER_ID"] || "a9daba92-43c7-4471-b81c-689e1f17357e"
API_KEY_PATH = File.expand_path(
  ENV["ASC_KEY_PATH"] || "~/.appstoreconnect/private_keys/AuthKey_#{API_KEY_ID}.p8"
)

def asc_api_key
  app_store_connect_api_key(
    key_id: API_KEY_ID,
    issuer_id: API_ISSUER_ID,
    key_filepath: API_KEY_PATH,
    in_house: false,
  )
end

platform :ios do
  desc "Apple Distribution sertifikası + App Store provisioning profili oluştur"
  lane :signing do
    api_key = asc_api_key

    # Apple Distribution sertifikası — varsa indirir, yoksa oluşturur.
    cert(
      api_key: api_key,
      development: false,
      output_path: "./certs",
    )

    # App Store provisioning profili — com.parasende.app
    sigh(
      api_key: api_key,
      app_identifier: APP_IDENTIFIER,
      provisioning_name: "ParaSende App Store",
      force: true,
    )

    # Xcode projesini manuel imzalamaya çevir (headless build için güvenli).
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "Runner.xcodeproj",
      team_id: TEAM_ID,
      code_sign_identity: "Apple Distribution",
      profile_name: lane_context[SharedValues::SIGH_NAME],
      bundle_identifier: APP_IDENTIFIER,
      targets: ["Runner"],
    )
  end

  desc "Flutter ile imzalı App Store IPA üret (prod API_BASE gömülü)"
  lane :build do
    # API_BASE/WS_BASE her zaman prod'a gömülür; release build'in localhost'a
    # düşüp App Store'da giriş/kayıt patlatması bir daha yaşanmasın.
    Dir.chdir("../..") do
      sh(
        "flutter build ipa --release " \
        "--dart-define=API_BASE=https://toptanperakende.online/api/v1 " \
        "--dart-define=WS_BASE=wss://toptanperakende.online/api/v1/ws"
      )
    end
  end

  desc "Build + TestFlight'a yükle"
  lane :beta do
    api_key = asc_api_key
    upload_to_testflight(
      api_key: api_key,
      ipa: "../build/ios/ipa/ParaSende.ipa",
      skip_waiting_for_build_processing: true,
      distribute_external: false,
    )
  end

  desc "App Store'dan mevcut metadata'yı çek (yedek için)"
  lane :download_metadata do
    api_key = asc_api_key
    deliver(
      api_key: api_key,
      run_precheck_before_submit: false,
    ) do |options|
      # download-only path
    end
  end

  desc "Sadece review information (notes + demo creds + iletişim) güncelle"
  lane :update_review_info do
    api_key = asc_api_key
    deliver(
      api_key: api_key,
      submit_for_review: false,
      force: true,
      skip_binary_upload: true,
      skip_screenshots: true,
      skip_metadata: true,                     # metni/keyword vs DOKUNMA
      skip_app_version_update: true,
      precheck_include_in_app_purchases: false,
      run_precheck_before_submit: false,
      automatic_release: false,
    )
  end

  desc "App Store metadata + screenshot yükle (review'a göndermez)"
  lane :upload_metadata do
    api_key = asc_api_key
    deliver(
      api_key: api_key,
      submit_for_review: false,
      force: true,
      skip_binary_upload: true,
      overwrite_screenshots: true,
      precheck_include_in_app_purchases: false,
      run_precheck_before_submit: false,
    )
  end

  desc "App Store review'a gönder (App Privacy doldurulduktan sonra)"
  lane :submit do
    api_key = asc_api_key
    deliver(
      api_key: api_key,
      submit_for_review: true,
      force: true,
      skip_binary_upload: true,
      skip_screenshots: true,
      skip_metadata: true,
      precheck_include_in_app_purchases: false,
      run_precheck_before_submit: false,
      submission_information: {
        export_compliance_uses_encryption: false,
        add_id_info_uses_idfa: false,
        content_rights_contains_third_party_content: false,
      },
    )
  end
end
